{
  "manifest_version": 3,
  "name": "BB Reminder",
  "version": "0.1.0",
  "description": "Right-click selected text to schedule a Google Calendar follow-up.",
  "permissions": ["contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
